# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_DB=darkweb_monitor
POSTGRES_USER=dwm_user
POSTGRES_PASSWORD=change_me_in_production

# ============================================================
# Redis
# ============================================================
REDIS_PASSWORD=change_me_in_production

# ============================================================
# Auth — generate SECRET_KEY with: openssl rand -hex 32
# ============================================================
SECRET_KEY=generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ============================================================
# Elasticsearch
# ============================================================
ELASTICSEARCH_URL=http://elasticsearch:9200

# ============================================================
# Tor proxy
# The dperson/torproxy container exposes SOCKS5 on port 9050
# and an HTTP proxy (Privoxy) on port 8118.
# Use socks5h:// so .onion DNS resolves through Tor, not locally.
# ============================================================
TOR_PROXY=socks5h://tor:9050

# Control port for circuit rotation via stem.
# Leave TOR_CONTROL_PASSWORD empty if using cookie auth (default in dperson/torproxy).
TOR_CONTROL_PORT=9051
TOR_CONTROL_PASSWORD=

# ============================================================
# SMTP — for email alert delivery
# Leave blank to disable email alerts.
# ============================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ============================================================
# Slack — optional webhook for alert delivery
# Create an incoming webhook at: https://api.slack.com/apps
# ============================================================
SLACK_WEBHOOK_URL=

# ============================================================
# Generic webhook — optional POST endpoint for SIEM integration
# ============================================================
ALERT_WEBHOOK_URL=

# ============================================================
# Crawler tuning
# CRAWL_TIMEOUT: seconds before a single .onion request times out
# CIRCUIT_ROTATE_EVERY: rotate Tor circuit after this many requests
# ============================================================
CRAWL_TIMEOUT=30
CIRCUIT_ROTATE_EVERY=5

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
